{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationDir": "dist/types",
    "rootDir": "./src",
    "noImplicitAny": true,
    "strict": false,
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
